
config tgwol 'main'
	option enabled '0'
	option bot_token ''
	option poll_timeout '50'
	option access_mode 'whitelist'
	option log_level 'info'
	option ssh_keydir '/etc/tgwol/keys'

config user 'admin_example'
	option chat_id ''
	option name 'Admin'
	option role 'admin'
	list permissions 'all'

config device 'pc1'
	option name 'Home PC'
	option mac '00:00:00:00:00:00'
	option ip ''
	option broadcast '255.255.255.255'
	option wol_port '9'
	option ssh_user ''
	option ssh_port '22'
	option ssh_key ''
	option ssh_host ''
	list allowed_users 'all'

config router 'router'
	option allow_status '1'
	option allow_clients '1'
	option allow_reboot '0'
	option allow_shell '0'
	option allow_speedtest '0'
