#!/bin/sh /etc/rc.common
# Telegram WOL bot for OpenWRT

USE_PROCD=1
START=99
STOP=10

PROG=/usr/bin/tgwol-bot
CONF=/etc/config/tgwol

start_service() {
	config_load tgwol
	local bot_token
	config_get bot_token main bot_token

	[ -n "$bot_token" ] || {
		logger -t tgwol "bot_token is empty, refusing to start"
		return 0
	}

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file "$CONF"
	procd_set_param pidfile /var/run/tgwol.pid
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "tgwol"
}
